# Dudenest Backend — Environment Variables
# Copy as .env and fill in values (do NOT commit .env to the repo)
# Deploy: place .env in the same directory as docker-stack.yml on the Swarm manager

# PostgreSQL (Citus coordinator: 192.168.1.223)
DB_URL=postgres://dudenest:PASSWORD@192.168.1.223:5432/dudenest?sslmode=disable

# Redis (same Swarm stack)
REDIS_URL=redis://:REDIS_PASSWORD@redis:6379/0
REDIS_PASSWORD=REDIS_PASSWORD

# JWT (generate: openssl rand -hex 32)
JWT_SECRET=GENERATE_RANDOM_32_BYTE_KEY

# Headscale API
HEADSCALE_API_URL=http://headscale:8080
HEADSCALE_API_KEY=KEY_FROM_HEADSCALE

# OAuth providers (set via GitHub Secrets in CI)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
APPLE_CLIENT_ID=

# App URL (used as OAuth return URL)
APP_URL=https://dudenest.com
