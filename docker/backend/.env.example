# Dudenest Backend — Environment Variables
# Skopiuj jako .env i uzupełnij wartości (NIE commituj .env do repo)
# Deploy: umieść .env w tym samym katalogu co docker-stack.yml na Swarm managerze

# PostgreSQL (Citus coordinator: 192.168.1.223)
DB_URL=postgres://dudenest:HASLO@192.168.1.223:5432/dudenest?sslmode=disable

# Redis (w tym samym Swarm stack)
REDIS_URL=redis://:HASLO_REDIS@redis:6379/0
REDIS_PASSWORD=HASLO_REDIS

# JWT (generuj: openssl rand -hex 32)
JWT_SECRET=WYGENERUJ_LOSOWY_KLUCZ_32_BAJTY

# Headscale API
HEADSCALE_API_URL=http://headscale:8080
HEADSCALE_API_KEY=KLUCZ_Z_HEADSCALE
